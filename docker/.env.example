# GlobalActivityBot - Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ============================================================
# Discord Bot
# ============================================================

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ============================================================
# Database (MariaDB)
# ============================================================

# Full connection string for the bot to connect to MariaDB
# Format: Server=<host>;Port=3306;Database=<db>;User=<user>;Password=<password>
DB_CONNECTION_STRING=Server=db;Port=3306;Database=discord_activity;User=botuser;Password=changeme_bot_password

# MariaDB root password (used by Docker Compose to initialize the DB container)
MYSQL_ROOT_PASSWORD=changeme_root_password

# Database name
MYSQL_DATABASE=discord_activity

# Database user and password for the bot
DB_USER=botuser
DB_PASSWORD=changeme_bot_password

# ============================================================
# Runtime
# ============================================================

# ASP.NET Core environment (Development, Staging, Production)
DOTNET_ENVIRONMENT=Production
